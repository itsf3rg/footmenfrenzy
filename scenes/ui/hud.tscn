[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/ui/hud_manager.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/ui/icon_truffle_blast.png" id="2_truffle"]
[ext_resource type="Texture2D" path="res://assets/ui/icon_gummy_slam.png" id="3_gummy"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_bg"]
bg_color = Color(0.1, 0.1, 0.15, 0.8)

[node name="HUD" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="BottomPanel" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -120.0
grow_horizontal = 2
grow_vertical = 0
theme_override_styles/panel = SubResource("StyleBoxFlat_bg")

[node name="HeroCenter" type="HBoxContainer" parent="BottomPanel"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -50.0
offset_right = 200.0
offset_bottom = 50.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 20

[node name="Portrait" type="ColorRect" parent="BottomPanel/HeroCenter"]
custom_minimum_size = Vector2(80, 80)
layout_mode = 2
color = Color(0.3, 0.3, 0.3, 1)

[node name="Stats" type="VBoxContainer" parent="BottomPanel/HeroCenter"]
custom_minimum_size = Vector2(150, 0)
layout_mode = 2
alignment = 1

[node name="HPBar" type="ProgressBar" parent="BottomPanel/HeroCenter/Stats"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2
value = 100.0
show_percentage = false

[node name="ManaBar" type="ProgressBar" parent="BottomPanel/HeroCenter/Stats"]
custom_minimum_size = Vector2(0, 15)
layout_mode = 2
value = 100.0
show_percentage = false

[node name="Abilities" type="HBoxContainer" parent="BottomPanel/HeroCenter"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Ability1" type="TextureRect" parent="BottomPanel/HeroCenter/Abilities"]
custom_minimum_size = Vector2(80, 80)
layout_mode = 2
texture = ExtResource("2_truffle")
expand_mode = 1

[node name="Ability2" type="TextureRect" parent="BottomPanel/HeroCenter/Abilities"]
custom_minimum_size = Vector2(80, 80)
layout_mode = 2
texture = ExtResource("3_gummy")
expand_mode = 1

[node name="RTSPanel" type="VBoxContainer" parent="BottomPanel"]
layout_mode = 1
anchors_preset = 6
anchor_left = 1.0
anchor_top = 0.5
anchor_right = 1.0
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -40.0
offset_right = -20.0
offset_bottom = 40.0
grow_horizontal = 0
grow_vertical = 2

[node name="GoldContainer" type="HBoxContainer" parent="BottomPanel/RTSPanel"]
layout_mode = 2

[node name="Label" type="Label" parent="BottomPanel/RTSPanel/GoldContainer"]
layout_mode = 2
text = "Gold: "

[node name="GoldAmount" type="Label" parent="BottomPanel/RTSPanel/GoldContainer"]
layout_mode = 2
text = "0"

[node name="UpgradeButton" type="Button" parent="BottomPanel/RTSPanel"]
layout_mode = 2
text = "Upgrade Base"

[connection signal="pressed" from="BottomPanel/RTSPanel/UpgradeButton" to="." method="_on_upgrade_button_pressed"]
